\section*{סעיף ב'}
\begin{gather*}
    T:\mathrm{Mat}_2\left(\mathbb{R}\right) \to \mathrm{Mat}_2\left(\mathbb{R}\right) \\
    A\mapsto \begin{pmatrix}
        0 & 1 \\ 1 & 0
    \end{pmatrix}A
\end{gather*}
\section*{סעיף ג'}
\begin{gather*}
    T:\mathbb{C}_2\left[x\right] \to\mathbb{C}_2\left[x\right]  \\
    p\left(x\right)\mapsto p'\left(x\right)
